{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.py",   "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "src": "/(.*)",     "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/solar_model?action=build", "schedule": "0 4 * * *" }
  ]
}
